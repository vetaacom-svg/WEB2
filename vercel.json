{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self), payment=(), interest-cohort=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/rest/v1/:path*",
      "destination": "https://lubeapgnjpvlxidxfnhb.supabase.co/rest/v1/:path*"
    },
    {
      "source": "/auth/v1/:path*",
      "destination": "https://lubeapgnjpvlxidxfnhb.supabase.co/auth/v1/:path*"
    },
    {
      "source": "/storage/v1/:path*",
      "destination": "https://lubeapgnjpvlxidxfnhb.supabase.co/storage/v1/:path*"
    },
    {
      "source": "/realtime/v1/:path*",
      "destination": "https://lubeapgnjpvlxidxfnhb.supabase.co/realtime/v1/:path*"
    },
    {
      "source": "/functions/v1/:path*",
      "destination": "https://lubeapgnjpvlxidxfnhb.supabase.co/functions/v1/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
