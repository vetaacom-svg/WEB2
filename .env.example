# URL Supabase directe
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Clé anonyme Supabase
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# En dev, le client utilise le proxy Vite (localhost:3001 → Supabase) par défaut.
# Si vous voulez forcer HTTPS direct vers *.supabase.co : VITE_SUPABASE_DEV_PROXY=false
# Optionnel : tout forcer en direct (images + API) même en dev :
# VITE_SUPABASE_ALWAYS_DIRECT=true

# Optionnel : seuil (octets) pour vider auto panier/favoris/cache locale au chargement (défaut ~2621440)
# VITE_AUTO_CLEAR_STORAGE_BYTES=3000000

